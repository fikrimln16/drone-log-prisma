generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Flight {
  id Int @id @default(autoincrement())

  flight_id String

  mission_name String

  flight_date DateTime

  ama String?

  estate String?

  pilot String?

  battery_id String?

  battery_id_2 String?

  battery_color String?

  start_percent Int?

  end_percent Int?

  start_volt Float?

  end_volt Float?

  duration_min Int?

  start_time DateTime?

  end_time DateTime?

  notes String? @db.Text

  created_at DateTime @default(now())

  @@map("drone_flight_history")
}
